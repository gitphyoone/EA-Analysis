# Database
DATABASE_URL=postgresql+asyncpg://ea_user:ea_pass@localhost:5432/ea_db
POSTGRES_USER=ea_user
POSTGRES_PASSWORD=ea_pass
POSTGRES_DB=ea_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
API_SECRET_KEY=change_me_in_production_use_32_char_random_string
ENVIRONMENT=development

# News API
TRADING_ECONOMICS_API_KEY=your_key_here
# FIX: block trading when API unavailable (true = safe default)
NEWS_FAIL_SAFE_BLOCK=true
NEWS_BLACKOUT_MINUTES=30

# MT4 Account Info
MT4_ACCOUNT_CURRENCY=USD

# Circuit Breakers
CB_DAILY_DD_PCT=3.0
CB_WEEKLY_DD_PCT=6.0
CB_MONTHLY_DD_PCT=10.0

# Risk
RISK_PER_TRADE_PCT=0.25
ATR_SL_MULTIPLIER=1.5
ATR_TP_MULTIPLIER=3.0
MAX_OPEN_POSITIONS=3
MAX_SPREAD_MULTIPLIER=2.0
ATR_MIN_THRESHOLD=0.0005

# FIX: break-even buffer (1 pip away from exact entry to avoid stop-hunt)
BE_BUFFER_PIPS=1.0

# Correlation — FIX: extended from 20 to 60 periods (20 = 2.5 days, too noisy)
CORRELATION_WINDOW=60
CORRELATION_MAX=0.80

# Signal
RSI_BUY_MIN=55.0
RSI_BUY_MAX=70.0
RSI_SELL_MIN=30.0
RSI_SELL_MAX=45.0
ADX_MIN=25.0
# FIX: strong ADX relaxes RSI cap (avoids missing the strongest trend candles)
ADX_STRONG_THRESHOLD=40.0
RSI_BUY_MAX_STRONG=80.0
RSI_SELL_MIN_STRONG=20.0

# FIX: regime detection (EMA must be at least 0.1% apart to confirm trend)
EMA_CONVERGENCE_MIN_PCT=0.001
# FIX: candle body guard (reject entry if last candle body > 1.5 × ATR)
CANDLE_BODY_MAX_ATR_MULT=1.5

# Session (UTC)
LONDON_OPEN=08:00
LONDON_CLOSE=17:00
NY_OPEN=13:00
NY_CLOSE=22:00
# FIX: Friday close hour — no new trades + close all positions after this UTC hour
FRIDAY_CLOSE_HOUR_UTC=20

# Trade management
# Option: trail from +1R; false = trail only after +2R partial close (original behaviour)
TRAIL_FROM_1R=false

# Alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
